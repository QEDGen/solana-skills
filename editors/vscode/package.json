{
  "name": "qedspec",
  "displayName": "QEDSpec",
  "description": "Syntax highlighting for .qedspec verification spec files",
  "version": "0.1.0",
  "publisher": "qedgen",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "qedspec",
        "aliases": ["QEDSpec", "qedspec"],
        "extensions": [".qedspec"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "qedspec",
        "scopeName": "source.qedspec",
        "path": "./syntaxes/qedspec.tmLanguage.json"
      }
    ]
  }
}
