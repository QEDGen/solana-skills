{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "QEDSpec",
  "scopeName": "source.qedspec",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#top-level-keywords" },
    { "include": "#block-keywords" },
    { "include": "#handler-clauses" },
    { "include": "#account-descriptors" },
    { "include": "#operators" },
    { "include": "#types" },
    { "include": "#constants" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.qedspec",
          "match": "#.*$"
        },
        {
          "name": "comment.line.doc.qedspec",
          "match": "///.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.qedspec",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.qedspec", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.qedspec",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "top-level-keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.qedspec",
          "match": "\\b(spec|state|account|lifecycle|pda|errors|event|const|handler|operation|instruction)\\b"
        },
        {
          "name": "keyword.property.qedspec",
          "match": "\\b(property|invariant|cover|liveness|environment)\\b"
        }
      ]
    },
    "block-keywords": {
      "patterns": [
        {
          "name": "keyword.other.qedspec",
          "match": "\\b(accounts|transfers|takes|effect|context|guard|cpi|input_layout|insn_layout)\\b"
        }
      ]
    },
    "handler-clauses": {
      "patterns": [
        {
          "name": "keyword.control.qedspec",
          "match": "\\b(who|when|then|on|emits|aborts_if|with)\\b"
        },
        {
          "name": "keyword.operator.logical.qedspec",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.transfer.qedspec",
          "match": "\\b(from|to|amount|authority)\\b"
        },
        {
          "name": "keyword.property-clause.qedspec",
          "match": "\\b(expr|preserved_by|trace|from|leads_to|via|within|mutates|constraint)\\b"
        }
      ]
    },
    "account-descriptors": {
      "patterns": [
        {
          "name": "storage.modifier.qedspec",
          "match": "\\b(signer|writable|readonly|program|type)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.qedspec",
          "match": "(==|!=|>=|<=|>|<|\\+=|-=)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.qedspec",
          "match": "\\b(Pubkey|U8|U16|U32|U64|U128|Bool|Ptr|Color|String)\\b"
        },
        {
          "name": "entity.name.type.token.qedspec",
          "match": "\\b(token)(?=\\s*[,}]|$)"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.qedspec",
          "match": "\\b(all|true|false|null)\\b"
        }
      ]
    }
  }
}
