import Spec
import QEDGen.Solana.Verify

/-!
# Escrow Proofs

Proofs of all properties generated by the qedspec DSL in Spec.lean.
Every theorem references DSL-generated definitions — no hand-written
transitions or custom state types.

Verified properties:
  - Access control (signer checks) for all 3 operations
  - State machine (lifecycle transitions) for all 3 operations
  - CPI correctness (program ID, accounts, discriminator) for all 3 operations
  - U64 bounds preservation for all 3 operations
  - Conservation invariant
-/

open QEDGen.Solana
open Escrow

namespace Escrow.Proofs

-- ============================================================================
-- Initialize
-- ============================================================================

theorem initialize_access_control (s : State) (p : Pubkey)
    (h : initializeTransition s p ≠ none) :
    p = s.initializer := by
  simp [initializeTransition] at h
  exact h.1

theorem initialize_state_machine (s s' : State) (p : Pubkey)
    (h : initializeTransition s p = some s') :
    s.status = .Uninitialized ∧ s'.status = .Open := by
  simp [initializeTransition] at h
  obtain ⟨⟨_, h_pre⟩, h_eq⟩ := h
  exact ⟨h_pre, by subst h_eq; rfl⟩

theorem initialize_cpi_correct (ctx : initializeCpiContext) :
    let cpi := initialize_build_cpi ctx
    targetsProgram cpi TOKEN_PROGRAM_ID ∧
    accountAt cpi 0 ctx.initializer_deposit false true ∧
    accountAt cpi 1 ctx.escrow_token false true ∧
    accountAt cpi 2 ctx.initializer true false ∧
    hasDiscriminator cpi DISC_TRANSFER := by
  exact ⟨rfl, rfl, rfl, rfl, rfl⟩

theorem initialize_u64_bounds (s s' : State) (p : Pubkey)
    (h_valid : valid_u64 s.initializer_amount ∧ valid_u64 s.taker_amount)
    (h : initializeTransition s p = some s') :
    valid_u64 s'.initializer_amount ∧ valid_u64 s'.taker_amount := by
  simp [initializeTransition] at h
  obtain ⟨_, h_eq⟩ := h
  subst h_eq; exact h_valid

