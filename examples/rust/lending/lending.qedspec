// Lending Protocol Verification Spec
//
// A simple lending pool: depositors add liquidity, borrowers take loans
// against collateral, and repay or get liquidated.

spec Lending

// State as algebraic data types: fields live inside the variant they belong to.
// An Uninitialized pool has no fields. An Active pool has authority, balances, etc.

type Pool
  | Uninitialized
  | Active of {
      authority      : Pubkey,
      total_deposits : U64,
      total_borrows  : U64,
      interest_rate  : U64,
    }
  | Paused

type Loan
  | Empty
  | Active of {
      borrower   : Pubkey,
      pool       : Pubkey,
      amount     : U64,
      collateral : U64,
    }
  | Liquidated

type Error
  | InsufficientLiquidity
  | InsufficientCollateral
  | Unauthorized
  | AlreadyActive
  | InvalidAmount
  | MathOverflow
  | AccountHealthy

pda pool ["pool", authority]
pda loan ["loan", pool, borrower]

event PoolInitialized { authority : Pubkey, rate : U64 }
event Deposited       { depositor : Pubkey, amount : U64 }
event Borrowed        { borrower : Pubkey, amount : U64 }
event Repaid          { borrower : Pubkey, amount : U64 }
event LoanLiquidated  { borrower : Pubkey, amount : U64 }

// Handlers: name (inputs) : PreState -> PostState

/// Initialize the lending pool with an interest rate
handler init_pool (rate : U64) : Pool.Uninitialized -> Pool.Active {
  auth authority

  accounts {
    authority      : signer, writable
    pool           : writable, pda ["pool", authority]
    system_program : program
  }

  requires rate > 0 else InvalidAmount

  effect {
    interest_rate  := rate
    total_deposits := 0
    total_borrows  := 0
  }

  emits PoolInitialized
}

/// Deposit tokens into the pool — anyone can deposit; the depositor
/// receives credit by being the source-account owner of the token
/// transfer, not by being privileged.
handler deposit (amount : U64) : Pool.Active -> Pool.Active {
  permissionless

  accounts {
    depositor     : signer, writable
    pool          : writable, pda ["pool", authority]
    pool_vault    : writable, token, authority pool
    depositor_ta  : writable, token
    token_program : program
  }

  requires amount > 0 else InvalidAmount

  effect {
    total_deposits += amount
  }

  transfers {
    from depositor_ta to pool_vault amount amount authority depositor
  }

  emits Deposited
}

/// Borrow tokens from the pool against collateral
handler borrow (amount : U64) (collateral : U64) : Loan.Empty -> Loan.Active {
  auth borrower

  accounts {
    borrower       : signer, writable
    loan           : writable, pda ["loan", pool, borrower]
    pool           : writable, pda ["pool", authority]
    pool_vault     : writable, token, authority pool
    borrower_ta    : writable, token
    token_program  : program
    system_program : program
  }

  requires amount > 0 /\ collateral > 0 else InvalidAmount

  effect {
    amount     := amount
    collateral := collateral
  }

  transfers {
    from pool_vault to borrower_ta amount amount authority pool
  }

  emits Borrowed
}

/// Repay a loan in full
handler repay : Loan.Active -> Loan.Empty {
  auth borrower

  accounts {
    borrower      : signer, writable
    loan          : writable, pda ["loan", pool, borrower]
    pool          : writable, pda ["pool", authority]
    pool_vault    : writable, token, authority pool
    borrower_ta   : writable, token
    token_program : program
  }

  effect {
    amount     := 0
    collateral := 0
  }

  transfers {
    from borrower_ta to pool_vault amount amount authority borrower
  }

  emits Repaid
}

/// Liquidate an undercollateralized loan — anyone can liquidate; the
/// authorization is the health check, not the liquidator's identity.
handler liquidate : Loan.Active -> Loan.Liquidated {
  permissionless

  accounts {
    liquidator     : signer, writable
    loan           : writable, pda ["loan", pool, borrower]
    pool           : writable, pda ["pool", authority]
    pool_vault     : writable, token, authority pool
    liquidator_ta  : writable, token
    token_program  : program
  }

  // Liquidations only fire when the loan is underwater — debt exceeds
  // collateral. Healthy positions are protected; only insolvent loans
  // can be seized. Real protocols would parameterize this by an LTV
  // factor (e.g. `amount * 100 > collateral * 80` for an 80% trigger);
  // the simplest formulation captures the security shape.
  requires state.amount > state.collateral else AccountHealthy

  effect {
    amount := 0
  }

  transfers {
    from pool_vault to liquidator_ta amount amount authority pool
  }

  emits LoanLiquidated
}

// Properties

property pool_solvency :
  forall s : Pool.Active, s.total_deposits >= s.total_borrows
  preserved_by all

invariant collateral_backing :
  forall l : Loan.Active, l.collateral > 0

cover borrow_repay_cycle [init_pool, deposit, borrow, repay]
cover liquidation_path   [init_pool, deposit, borrow, liquidate]

liveness loan_settles : Loan.Active ~> Loan.Empty via [repay] within 1

environment interest_rate_change {
  mutates interest_rate : U64
  constraint interest_rate > 0
}
