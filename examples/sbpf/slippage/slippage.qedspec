# Slippage Guard — Balance Check
#
# Compares token account balance against a minimum threshold.
# If balance is below minimum, rejects. Otherwise accepts.

spec Slippage

errors [
  SlippageExceeded = 1 "Token balance below minimum threshold"
]

handler check_slippage {
  accounts {
    token_account : readonly
  }

  requires token_balance > minimum_balance else SlippageExceeded
}
